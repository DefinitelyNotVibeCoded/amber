{
  "name": "amber",
  "version": "0.18.0",
  "private": true,
  "description": "Amber: an Obsidian-style local app for OKF (Open Knowledge Format) bundles.",
  "author": "Amber",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "mcp": "tsx mcp/server.ts",
    "mcp:http": "tsx mcp/http-server.ts",
    "electron": "electron electron/main.js",
    "electron:dev": "concurrently -k -n NEXT,ELECTRON -c blue,yellow \"npm:dev\" \"wait-on http://localhost:3000 && cross-env AMBER_ELECTRON_DEV=1 electron electron/main.js\"",
    "dist": "next build && node scripts/prepare-standalone.js && electron-builder"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.469.0",
    "markitdown-js": "^0.0.14",
    "next": "15.5.20",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.amber.okfvault",
    "productName": "Amber",
    "files": [
      ".next/standalone/**/*",
      "electron/**/*",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "vault",
        "to": "app/vault"
      }
    ],
    "asar": false,
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "allowScripts": {
    "onnxruntime-node@1.24.3": true,
    "protobufjs@7.6.5": true,
    "sharp@0.34.5": true,
    "esbuild@0.28.1": true,
    "electron-winstaller@5.4.0": true
  }
}
